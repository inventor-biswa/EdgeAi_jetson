# ─── Jetson Offline Edition — Environment Variables ──────────────────────────
#
# Copy this file: cp .env.example .env
# No API keys needed — everything runs locally on the Jetson!

# ── LLM Server (llama-server via Docker on Jetson) ───────────────────────────
# Default: http://127.0.0.1:8080/v1/chat/completions
# Run start_llm.sh on the Jetson first, then this app.
LLM_API_URL=http://127.0.0.1:8080/v1/chat/completions
LLM_MODEL=my_model

# ── SQLite Database ───────────────────────────────────────────────────────────
# Path where analyses are stored. Default: ./jetson_analyses.db
# SQLITE_DB_PATH=./jetson_analyses.db

# ── Optional: Pre-scraped market data cache ───────────────────────────────────
# If you scraped market data ahead of time (when internet was available),
# point this to your JSON file and it will be used instead of the LLM fallback.
# Format: {"competitors": "...", "market_size": "...", "recent_news": "..."}
# OFFLINE_MARKET_CACHE_FILE=./market_cache.json

# ─────────────────────────────────────────────────────────────────────────────
# Cloud keys below are NO LONGER NEEDED (kept here for reference only):
# GEMINI_API_KEY=    ← replaced by LLM_API_URL above
# MONGO_URI=         ← replaced by SQLite (no config needed)
# TAVILY_API_KEY=    ← replaced by offline fallback