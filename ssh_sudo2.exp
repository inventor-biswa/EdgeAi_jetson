#!/usr/bin/expect -f
# ssh_sudo2.exp — Run remote commands with infinite timeout

set timeout -1
set ip       "192.168.1.32"
set user     "biswa"
set password "biswa"
set cmd      [lindex $argv 0]

spawn ssh -t -o StrictHostKeyChecking=no $user@$ip $cmd

expect {
    "assword" {
        send "$password\r"
        exp_continue
    }
    eof {
        # done
    }
}
