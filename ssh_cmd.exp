#!/usr/bin/expect -f

set timeout -1
set ip "192.168.1.32"
set user "biswa"
set password "biswa"
set cmd [lindex $argv 0]

spawn ssh -o StrictHostKeyChecking=no $user@$ip $cmd

expect {
    "assword:" {
        send "$password\r"
        exp_continue
    }
    timeout {
        puts "Connection timeout"
        exit 1
    }
    eof {
        # done
    }
}
